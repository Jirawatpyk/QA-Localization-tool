</sdl:seg-defs>
</trans-unit>
<trans-unit id="tu-130">
<seg-source>
<mrk mtype="seg" mid="130">Error code 123: The server encountered an unexpected condition that prevented it from fulfilling the request.</mrk>
</seg-source>
<target>
