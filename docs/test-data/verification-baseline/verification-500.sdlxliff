<sdl:seg id="137" conf="Draft" percent="64"/>
</sdl:seg-defs>
</trans-unit>
<trans-unit id="tu-138">
<seg-source>
<mrk mtype="seg" mid="138">Performance metrics indicate that response time has improved by 179ms since the last update.</mrk>
</seg-source>
<target>
