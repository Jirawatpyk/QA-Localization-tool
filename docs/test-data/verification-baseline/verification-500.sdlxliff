<sdl:seg id="138" conf="ApprovedTranslation" percent="100"/>
</sdl:seg-defs>
</trans-unit>
<trans-unit id="tu-139">
<seg-source>
<mrk mtype="seg" mid="139">The new feature allows users to export data in 186 formats: PDF, Excel, and CSV.</mrk>
</seg-source>
<target>
<mrk mtype="seg" mid="139">ฟีเจอร์ใหม่ช่วยให้ผู้ใช้สามารถส่งออกข้อมูลในรูปแบบ 186: PDF, Excel และ CSV</mrk>
</target>
