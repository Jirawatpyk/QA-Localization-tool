<sdl:seg id="314" conf="Translated" percent="42"/>
</sdl:seg-defs>
</trans-unit>
<trans-unit id="tu-315">
<seg-source>
<mrk mtype="seg" mid="315">The inventory system shows 518 items in stock across 3 warehouse locations.</mrk>
</seg-source>
<target>
<mrk mtype="seg" mid="315">ระบบสินค้าคงคลังแสดง 518 รายการในสต็อกใน 3 สถานที่คลังสินค้า</mrk>
