<sdl:seg-defs>
<sdl:seg id="376" conf="Translated" percent="40"/>
</sdl:seg-defs>
</trans-unit>
<trans-unit id="tu-377">
<seg-source>
<mrk mtype="seg" mid="377">The application supports 952 languages including Thai, Chinese, Japanese, and Korean.</mrk>
</seg-source>
<target>
<mrk mtype="seg" mid="377">แอปพลิเคชันรองรับ 952 ภาษา รวมถึงไทย จีน ญี่ปุ่น และเกาหลี</mrk>
