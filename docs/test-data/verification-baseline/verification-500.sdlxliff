<sdl:seg id="319" conf="Translated" percent="6"/>
</sdl:seg-defs>
</trans-unit>
<trans-unit id="tu-320">
<seg-source>
<mrk mtype="seg" mid="320">Security notice: Your session will expire in 553 minutes due to inactivity.</mrk>
</seg-source>
<target>
