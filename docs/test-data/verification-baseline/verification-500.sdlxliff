<sdl:seg id="329" conf="Translated" percent="35"/>
</sdl:seg-defs>
</trans-unit>
<trans-unit id="tu-330">
<seg-source>
<mrk mtype="seg" mid="330">For optimal performance, we recommend using the latest version of Chrome, Firefox, or Edge browser.</mrk>
</seg-source>
<target>
