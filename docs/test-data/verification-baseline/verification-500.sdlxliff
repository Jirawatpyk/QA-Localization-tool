<sdl:seg id="313" conf="ApprovedTranslation" percent="100"/>
</sdl:seg-defs>
</trans-unit>
<trans-unit id="tu-314">
<seg-source>
<mrk mtype="seg" mid="314">All team members must complete the certification exam with a minimum score of 511%.</mrk>
</seg-source>
<target>
