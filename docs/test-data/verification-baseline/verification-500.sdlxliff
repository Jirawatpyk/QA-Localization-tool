<sdl:seg-defs>
<sdl:seg id="126" conf="Translated" percent="22"/>
</sdl:seg-defs>
</trans-unit>
<trans-unit id="tu-127">
<seg-source>
<mrk mtype="seg" mid="127">Step 102: Review the document carefully before signing the agreement.</mrk>
</seg-source>
<target>
