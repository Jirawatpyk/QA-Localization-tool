</sdl:seg-defs>
</trans-unit>
<trans-unit id="tu-324">
<seg-source>
<mrk mtype="seg" mid="324">Click &quot;Next&quot; to continue or &quot;Back&quot; to return to the previous page.</mrk>
</seg-source>
<target>
