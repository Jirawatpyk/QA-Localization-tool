<trans-unit id="tu-36">
<seg-source>
<mrk mtype="seg" mid="36">For more information, please contact our support team at 365 or visit our help center.</mrk>
</seg-source>
<target>
<mrk mtype="seg" mid="36">สำหรับข้อมูลเพิ่มเติม กรุณาติดต่อทีมสนับสนุนของเราที่ 365 หรือเยี่ยมชมศูนย์ช่วยเหลือ</mrk>
</target>
<sdl:seg-defs>
<sdl:seg id="36" conf="Translated" percent="64"/>
</sdl:seg-defs>
