</target>
<sdl:seg-defs>
<sdl:seg id="104" conf="Translated" percent="39"/>
</sdl:seg-defs>
</trans-unit>
<trans-unit id="tu-105">
<seg-source>
<mrk mtype="seg" mid="105">The inventory system shows 848 items in stock across 23 warehouse locations.</mrk>
</seg-source>
