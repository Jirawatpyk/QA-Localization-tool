<sdl:seg id="321" conf="Translated" percent="32"/>
</sdl:seg-defs>
</trans-unit>
<trans-unit id="tu-322">
<seg-source>
<mrk mtype="seg" mid="322">Employees are required to complete 567 hours of professional development training annually.</mrk>
</seg-source>
<target>
<mrk mtype="seg" mid="322">พนักงานจำเป็นต้องเข้าร่วมการฝึกอบรมพัฒนาวิชาชีพ 567 ชั่วโมงต่อปี</mrk>
</target>
<sdl:seg-defs>
<sdl:seg id="322" conf="Draft" percent="45"/>
</sdl:seg-defs>
</trans-unit>
<trans-unit id="tu-323">
<seg-source>
<mrk mtype="seg" mid="323">The database backup was completed successfully at 574 with 27 records processed.</mrk>
</seg-source>
<target>
