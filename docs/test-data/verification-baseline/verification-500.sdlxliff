</sdl:seg-defs>
</trans-unit>
<trans-unit id="tu-331">
<seg-source>
<mrk mtype="seg" mid="331">Please ensure that all 630 participants have completed the registration form before the training session begins.</mrk>
</seg-source>
<target>
